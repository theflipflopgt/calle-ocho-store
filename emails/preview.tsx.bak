/**
 * Preview de Emails
 *
 * Para ver una preview de los emails en el navegador:
 *
 * 1. Ejecuta: npm run email:dev
 * 2. Abre: http://localhost:3001
 *
 * Si no tienes el script configurado, agrégalo a package.json:
 * "email:dev": "email dev"
 */

